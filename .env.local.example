# Local safe production-like mode (manual copy: cp .env.local.example .env)
ENV_MODE=local

# LLM: mock for offline dev, or openai with a real key
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
DEFAULT_MODEL=gpt-4o-mini
LLM_MAX_ATTEMPTS=2

# In-process async analysis runtime (part of API container, not a separate service yet)
ANALYSIS_RUNTIME_ENABLED=true
ANALYSIS_WORKER_CONCURRENCY=1
ANALYSIS_WORKER_BATCH_SIZE=1
ANALYSIS_WORKER_POLL_INTERVAL=1.0
ANALYSIS_JOB_MAX_ATTEMPTS=1

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/mini_app_db
DATABASE_URL_PSYCOPG2=postgresql+psycopg2://postgres:password@localhost:5433/mini_app_db

REDIS_HOST=localhost
REDIS_PORT=6379

BOT_TOKEN=
BOT_LINK=

OTLP_GRPC_ENDPOINT=http://localhost:4317
TRACEBACK_OUTPUT_ENABLED=False
